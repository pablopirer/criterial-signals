# Copy this file to `.env.local` (which is gitignored) and fill in the values.
# Used by `supabase functions serve sample-request --env-file .env.local`.

# Anthropic API key. Create at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin a different model. Defaults to claude-haiku-4-5-20251001.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Shared secret expected in the x-criterial-signal header on every POST.
# Generate with: openssl rand -hex 32
SAMPLE_REQUEST_SECRET=replace-me-with-a-long-random-string
